# Python
__pycache__/
*.pyc
.venv/

# Large UE source assets (raw LiDAR + DTM grid meshes/textures; multi-GB).
# Kept locally; never committed — the viewer uses the processed web/data/ output.
LIDAR/
MESHES/

# Generated/extracted artifacts (rebuild with tools/build_all.py)
web/data/
extracted/
*.log

# Transit/OSM build caches (large, regenerable). The small realtime JSON fixtures
# (VehiclePosition/TripUpdate/Alert) are kept — tools/serve.py --mock and
# tools/verify_transit.py replay them offline.
tools/_transit_samples/*.zip
tools/_transit_samples/osm_city.json

# Node (web viewer dev server)
node_modules/
web/node_modules/

# Transient offline test tileset (tools/make_test_tileset.py; built + torn down by
# tools/verify_photoreal.py)
web/_testtileset/

# Editor/OS cruft
.vscode/
Thumbs.db
.DS_Store

# Local secrets (API keys etc.) — never commit
.env
.env.*
!.env.example

# Photoreal tile cache (operational cache populated by tools/twin_server.py; transient,
# regenerable, and must not be redistributed — see README on Google's caching terms)
web/data/tilecache/

# Local scratch (not part of the project)
CLAUDE-FABLE-5.md

# YOLO model weights (auto-downloaded by the vision examples on first run)
*.pt
