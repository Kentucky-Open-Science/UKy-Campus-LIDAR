{
  "name": "lexington-digital-twin",
  "version": "1.0.0",
  "private": true,
  "description": "Three.js viewer for the Lexington Digital Twin: terrain + LiDAR + buildings + procedural city props. Pure static files, no build step.",
  "type": "module",
  "scripts": {
    "start": "http-server . -p 8000 -c-1 -o",
    "serve": "http-server . -p 8000 -c-1",
    "serve:python": "python -m http.server 8000",
    "vendor:tiles": "node lib/_vendor.mjs"
  },
  "devDependencies": {
    "3d-tiles-renderer": "0.3.43",
    "esbuild": "^0.28.1",
    "http-server": "^14.1.1",
    "three": "0.160.0"
  }
}
