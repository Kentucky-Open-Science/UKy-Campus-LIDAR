# Copy to .env (gitignored) and fill in. Loaded by tools/twin_server.py.
# Google Maps Platform key with the "Map Tiles API" enabled, for the optional
# photorealistic 3D-tiles basemap. Restrict it to your domain/referrer.
GOOGLE_MAPS_API_KEY=

# Optional: use a Cesium ion token instead (same Google dataset). Then set the token
# above in GOOGLE_MAPS_API_KEY and uncomment:
# PHOTOREAL_PROVIDER=ion
